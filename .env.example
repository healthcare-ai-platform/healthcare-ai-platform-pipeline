# =============================================================================
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# ── Postgres (operational DB — same one the backend uses) ────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/healthcare

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── MinIO / S3 ───────────────────────────────────────────────────────────────
S3_BUCKET=healthcare-docs
AWS_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# ── Snowflake (Snowpark session — used by scripts/ingest.py for structured
#    file COPY, and by scripts/schema.py to provision the warehouse) ─────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=HEALTHCARE
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN

# ── Snowpipe REST API (key-pair auth — separate from the password above) ─────
# One-time setup in Snowflake: ALTER USER <user> SET RSA_PUBLIC_KEY = '<public key>';
# Then paste the matching PRIVATE key's PEM content below (keep the newlines).
SNOWFLAKE_PRIVATE_KEY=

# Set this if you have a Snowflake storage integration configured for the S3
# bucket; otherwise scripts/schema.py falls back to inline AWS credentials.
SNOWFLAKE_STORAGE_INTEGRATION=

# ── Anthropic (PDF OCR extraction agent in scripts/ocr.py) ───────────────────
ANTHROPIC_API_KEY=your-key-here
